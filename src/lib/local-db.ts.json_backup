// ============ 公开 API ============

export async function getUsers(): Promise<User[]> {
  const local = await readLocal<User>(USERS_KEY);
  if (local.length > 0) {
    // 确保每条记录都有 id（兼容旧数据）
    let needsUpdate = false;
    for (let i = 0; i < local.length; i++) {
      if (!local[i].id) {
        local[i].id = `legacy_user_${i + 1}_${Date.now()}`;
        needsUpdate = true;
      }
    }
    if (needsUpdate) {
      await saveUsers(local);
    }
    return local;
  }
  const cloudData = await readFromCloud(USERS_KEY, DEFAULT_USERS) as User[];
  // 无云端配置时确保本地有默认数据
  await writeLocal(USERS_KEY, cloudData);
  return cloudData;
}

export async function saveUsers(users: User[]): Promise<boolean> {
  return writeToCloud(USERS_KEY, users);
}

export async function getHazards(): Promise<Hazard[]> {
  const local = await readLocal<Hazard>(HAZARDS_KEY);
  if (local.length > 0) {
    // 确保每条记录都有 id（兼容旧数据）
    let needsUpdate = false;
    for (let i = 0; i < local.length; i++) {
      if (!local[i].id) {
        local[i].id = `legacy_${i + 1}_${Date.now()}`;
        needsUpdate = true;
      }
    }
    if (needsUpdate) {
      await saveHazards(local);
    }
    return local;
  }
  return readFromCloud(HAZARDS_KEY, []) as Promise<Hazard[]>;
}

export async function saveHazards(hazards: Hazard[]): Promise<boolean> {
  return writeToCloud(HAZARDS_KEY, hazards);
}

export async function addHazard(hazard: Hazard): Promise<boolean> {
  const hazards = await getHazards();
  hazards.push(hazard);
  return saveHazards(hazards);
}

export async function updateHazard(id: string, updates: Partial<Hazard>): Promise<boolean> {
  const hazards = await getHazards();
  const idx = hazards.findIndex((h) => h.id === id);
  if (idx === -1) return false;
  hazards[idx] = { ...hazards[idx], ...updates };
  return saveHazards(hazards);
}

export async function deleteHazard(id: string): Promise<boolean> {
  const hazards = await getHazards();
  const filtered = hazards.filter((h) => h.id !== id);
  if (filtered.length === hazards.length) return false;
  return saveHazards(filtered);
}

export async function getRiskItems(): Promise<RiskItem[]> {
  const local = await readLocal<RiskItem>(RISK_ITEMS_KEY);
  if (local.length > 0) return local;
  const cloudData = await readFromCloud(RISK_ITEMS_KEY, DEFAULT_RISK_ITEMS) as RiskItem[];
  await writeLocal(RISK_ITEMS_KEY, cloudData);
  return cloudData;
}

export async function saveRiskItems(items: RiskItem[]): Promise<boolean> {
  return writeToCloud(RISK_ITEMS_KEY, items);
}

export async function addRiskItem(item: RiskItem): Promise<boolean> {
  const items = await getRiskItems();
  items.push(item);
  return saveRiskItems(items);
}

export async function updateRiskItem(id: string, updates: Partial<RiskItem>): Promise<boolean> {
  const items = await getRiskItems();
  const idx = items.findIndex((i) => i.id === id);
  if (idx === -1) return false;
  items[idx] = { ...items[idx], ...updates };
  return saveRiskItems(items);
}

export async function deleteRiskItem(id: string): Promise<boolean> {
  const items = await getRiskItems();
  const filtered = items.filter((i) => i.id !== id);
  if (filtered.length === items.length) return false;
  return saveRiskItems(filtered);
}

// 密码哈希函数统一在 crypto.ts 中定义，此处重导出以保持兼容
export { hashPassword, verifyPassword } from './crypto';

export async function getUserByUsername(username: string): Promise<User | null> {
  const users = await getUsers();
  return users.find((u) => u.username === username) || null;
}

export async function getUserById(id: string): Promise<User | null> {
  const users = await getUsers();
  return users.find((u) => u.id === id) || null;
}

export async function updateUser(id: string, updates: Partial<User>): Promise<boolean> {
  const users = await getUsers();
  const idx = users.findIndex((u) => u.id === id);
  if (idx === -1) return false;
  users[idx] = { ...users[idx], ...updates, updated_at: new Date().toISOString() };
  return saveUsers(users);
}

export async function createUser(data: any): Promise<User | null> {
  const users = await getUsers();
  if (users.some((u) => u.username === data.username)) return null;
  
  const newUser: User = {
    id: Date.now().toString(),
    username: data.username,
    password_hash: authHashPassword(data.password),
    role: data.role || 'inspector',
    name: data.name || '',
    employee_id: data.employee_id || '',
    inspection_center: data.inspection_center || '物资后勤中心',
    inspection_department: data.inspection_department || '',
    inspection_team: data.inspection_team || '',
    inspection_position: data.inspection_position || '',
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  };
  
  users.push(newUser);
  const ok = await saveUsers(users);
  return ok ? newUser : null;
}

export async function deleteUser(id: string): Promise<boolean> {
  const users = await getUsers();
  const filtered = users.filter((u) => u.id !== id);
  if (filtered.length === users.length) return false;
  return saveUsers(filtered);
}

export async function initializeData() {
  await getUsers();
  await getRiskItems();
}
