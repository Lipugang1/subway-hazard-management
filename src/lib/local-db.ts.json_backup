// 数据库存储层 - 基于云端对象存储
import { S3Storage } from 'coze-coding-dev-sdk';
import { promises as fs } from 'fs';
import path from 'path';
import { hashPassword as authHashPassword } from './crypto';

// 类型定义
interface User {
  id: string;
  username: string;
  password_hash: string;
  role: string;
  name: string;
  employee_id: string;
  inspection_center: string;
  inspection_department: string;
  inspection_team: string;
  inspection_position: string;
  created_at: string;
  updated_at: string;
}

interface Hazard {
  id: string;
  [key: string]: any;
}

interface RiskItem {
  id: string;
  [key: string]: any;
}

// 配置常量
const BACKUP_BUCKET = process.env.COZE_BUCKET_NAME || '';
const DATA_PREFIX = 'hazard-data/';
// 使用项目内 data/ 目录持久化，不再使用 /tmp（重启丢失）
const LOCAL_DATA_DIR = path.join(process.cwd(), 'data');

// 本地存储键名
const USERS_KEY = 'users.json';
const HAZARDS_KEY = 'hazards.json';
const RISK_ITEMS_KEY = 'risk-items.json';

// 客户端单例
let cloudStorage: S3Storage | null = null;

// 初始化存储
function initStorage(): S3Storage | null {
  if (!BACKUP_BUCKET) {
    console.log('[CloudDB] 未配置云端存储');
    return null;
  }
  
  if (!cloudStorage) {
    cloudStorage = new S3Storage({
      endpointUrl: process.env.COZE_BUCKET_ENDPOINT_URL,
      bucketName: BACKUP_BUCKET,
      region: 'cn-beijing',
    });
  }
  
  return cloudStorage;
}

// 辅助函数
function getLocalPath(fileName: string): string {
  return path.join(LOCAL_DATA_DIR, fileName);
}

function getCloudPrefix(fileName: string): string {
  const base = fileName.replace('.json', '');
  return `${DATA_PREFIX}${base}_`;
}

async function ensureLocal(): Promise<void> {
  try {
    await fs.mkdir(LOCAL_DATA_DIR, { recursive: true });
  } catch {}
}

// 本地读写
async function readLocal<T>(fileName: string): Promise<T[]> {
  try {
    const content = await fs.readFile(getLocalPath(fileName), 'utf-8');
    const data = JSON.parse(content);
    if (Array.isArray(data)) return data as T[];
  } catch {}
  return [];
}

async function writeLocal<T>(fileName: string, data: T): Promise<void> {
  await ensureLocal();
  await fs.writeFile(getLocalPath(fileName), JSON.stringify(data, null, 2));
}

// 云端读写
async function readFromCloud<T>(fileName: string, defaults: T): Promise<T> {
  const storage = initStorage();
  if (!storage) return defaults;
  
  const prefix = getCloudPrefix(fileName);
  
  try {
    const list = await storage.listFiles({ prefix });
    
    if (list.keys.length === 0) {
      console.log(`[CloudDB] 云端无数据: ${fileName}`);
      await writeToCloud(fileName, defaults);
      return defaults;
    }
    
    // 解析时间戳排序
    const files = list.keys
      .map(key => {
        const match = key.match(/_(\d+)_/);
        return { key, ts: match ? parseInt(match[1]) : 0 };
      })
      .sort((a, b) => b.ts - a.ts);
    
    const latestKey = files[0].key;
    const buffer = await storage.readFile({ fileKey: latestKey });
    const data = JSON.parse(buffer.toString());
    
    console.log(`[CloudDB] 云端读取: ${fileName} (${data.length}条)`);
    await writeLocal(fileName, data);
    
    return data as T;
  } catch (error: any) {
    console.error(`[CloudDB] 云端读取失败: ${fileName}`, error.message);
    return defaults;
  }
}

async function writeToCloud<T>(fileName: string, data: T): Promise<boolean> {
  await writeLocal(fileName, data);
  
  const storage = initStorage();
  if (!storage) return true;
  
  const timestamp = Date.now();
  const base = fileName.replace('.json', '');
  const key = `${DATA_PREFIX}${base}_${timestamp}.json`;
  
  try {
    await storage.uploadFile({
      fileContent: Buffer.from(JSON.stringify(data, null, 2)),
      fileName: key,
      contentType: 'application/json',
    });
    console.log(`[CloudDB] 云端写入: ${fileName}`);
    return true;
  } catch (error: any) {
    console.error(`[CloudDB] 云端写入失败: ${fileName}`, error.message);
    return false;
  }
}

